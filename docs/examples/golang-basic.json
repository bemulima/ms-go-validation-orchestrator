        ],
        "requiredStructs": [
          { "name": "User", "fields": ["ID", "Email"] }
        ],
        "requiredInterfaces": [
          { "name": "Runner", "fields": ["Run"] }
        ],
        "requiredMethods": [
          { "receiver": "Service", "name": "Handle" }
        ]
      }
    }
  ],
  "links": []
}
