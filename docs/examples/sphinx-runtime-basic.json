{
  "version": 1,
  "kind": "workspace_contract",
  "workspace": {
    "required_files": ["sphinx.conf"]
  },
  "stages": [
    {
      "id": "sphinx-runtime",
      "engine": "search.sphinx",
      "mode": "final",
      "targets": {
        "files": ["sphinx.conf"]
      },
      "rules": {
        "requiredIndexNames": ["products"]
      },
      "checks": {
        "setupQueries": [
          "INSERT INTO products(id, title) VALUES (1, 'phone')"
        ],
        "queries": [
          {
            "name": "search-products",
            "sql": "SELECT id, title FROM products WHERE MATCH('phone')",
            "expect": {
              "rows": [
                { "id": 1, "title": "phone" }
              ]
            }
          }
        ]
      }
    }
  ]
}
